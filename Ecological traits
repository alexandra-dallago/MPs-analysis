  labs(title = "Milan", x = "Dimensions", y = "Total Microparticles") +
  theme_minimal() +
  theme(plot.title = element_text(face = "bold", hjust = 0.5)) +
  scale_fill_viridis_d(direction = -1)

DIMENSION_PLOT <- p_dim_bolo + p_dim_milan

####################################################
### SEX ###
####################################################

p_sex_bolo <- ggplot(DB_bologna, aes(Sex, Tot_MP, fill = Sex)) +
