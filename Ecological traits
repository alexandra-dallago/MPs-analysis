SEX_PLOT <- p_sex_bolo + p_sex_milan

####################################################
############### NEST E SCOPA #######################
####################################################

DB_GLM_clean <- DB_GLM %>%
  filter(Sex == "F", !is.na(Nest), !is.na(Scopa), !is.na(Tot_MP), !is.na(City)) %>%
  mutate(Nest = factor(Nest),
         Scopa = factor(Scopa),
         City = factor(City)) %>%
  mutate(
    Nest = fct_recode(Nest,
                      "Ground Nest" = "G",
                      "Stem Nest" = "S",
                      "Cavity Nest" = "C",
                      "Brood parasitic" = "K"),
    Scopa = fct_recode(Scopa,
                       "Igluvia" = "I",
                       "Leg Scopae" = "Z",
                       "Ventral Scopae" = "V",
                       "Brood parasitic" = "K",
                       "Corbiculae" = "C")
  ) %>%
  droplevels()

nest_colors <- setNames(scales::alpha(viridis(length(levels(DB_GLM_clean$Nest))), 0.6),
                        levels(DB_GLM_clean$Nest))
scopa_colors <- setNames(scales::alpha(viridis(length(levels(DB_GLM_clean$Scopa))), 0.6),
                         levels(DB_GLM_clean$Scopa))

plot_nest <- ggplot(DB_GLM_clean, aes(Nest, Tot_MP, fill = Nest)) +
  geom_boxplot() +
  facet_wrap(~City) +
  scale_fill_manual(values = nest_colors) +
  labs(title = "Total Number of Microparticles per Nest (females only)",
       x = "Nest type", y = "Total Number of Microparticles") +
  theme_minimal() +
  theme(axis.text.x = element_text(angle = 30, hjust = 1),
        legend.position = "bottom")

plot_scopa <- ggplot(DB_GLM_clean, aes(Scopa, Tot_MP, fill = Scopa)) +
  geom_boxplot() +
  facet_wrap(~City) +
  scale_fill_manual(values = scopa_colors) +
  labs(title = "Total Number of Microparticles per Scopa (females only)",
       x = "Scopa type", y = "Total Number of Microparticles") +
  theme_minimal() +
  theme(axis.text.x = element_text(angle = 30, hjust = 1),
        legend.position = "bottom")

