library(dplyr)
library(forcats)
library(ggplot2)
library(viridis)
library(patchwork)
library(FSA)

############### GLM ###############

mod_qp1_Tot_MP <- glm(Tot_MP ~ Genus + Sex + Dimensions, 
                      family = quasipoisson, data = DB_GLM)
summary(mod_qp1_Tot_MP)

# Residui
residui12 <- residuals(mod_qp1_Tot_MP, type = "pearson")
shapiro.test(residui12)

# Test non parametrici
kruskal.test(Tot_MP ~ Sex, data = DB_GLM)
kruskal.test(Tot_MP ~ Dimensions, data = DB_GLM)

dunnTest(Tot_MP ~ Sex, data = DB_GLM, method = "bonferroni")
dunnTest(Tot_MP ~ Dimensions, data = DB_GLM, method = "bonferroni")

####################################################
### PREPARAZIONE DATI ###
####################################################

DB_MP1 <- DB_GLM %>%
  mutate(Genus = reorder(Genus, Tot_MP, FUN = median, decreasing = TRUE))

DB_bologna <- DB_MP1 %>% filter(City == "Bologna")
DB_milan   <- DB_MP1 %>% filter(City == "Milan")

####################################################
### GENUS ###
####################################################

order_bolo <- DB_bologna %>%
  group_by(Genus) %>%
  summarise(mediana = median(Tot_MP, na.rm = TRUE)) %>%
  arrange(mediana) %>%
  pull(Genus)

order_milan <- DB_milan %>%
  group_by(Genus) %>%
  summarise(mediana = median(Tot_MP, na.rm = TRUE)) %>%
  arrange(mediana) %>%
  pull(Genus)

DB_bologna <- DB_bologna %>% mutate(Genus_ord = factor(Genus, levels = order_bolo))
DB_milan   <- DB_milan   %>% mutate(Genus_ord = factor(Genus, levels = order_milan))

p_bolo <- ggplot(DB_bologna, aes(Genus_ord, Tot_MP, fill = Genus_ord)) +
  geom_boxplot(alpha = 0.6) +
  labs(title = "Bologna", x = "Genus", y = "Total Microparticles") +
  theme_minimal() +
  theme(axis.text.x = element_text(angle = 45, hjust = 1),
        plot.title = element_text(face = "bold", hjust = 0.5)) +
  scale_fill_viridis_d(guide = "none")

p_milan <- ggplot(DB_milan, aes(Genus_ord, Tot_MP, fill = Genus_ord)) +
  geom_boxplot(alpha = 0.6) +
  labs(title = "Milan", x = "Genus", y = "Total Microparticles") +
  theme_minimal() +
  theme(axis.text.x = element_text(angle = 45, hjust = 1),
        plot.title = element_text(face = "bold", hjust = 0.5)) +
  scale_fill_viridis_d(guide = "none")

GENUS_PLOT <- p_bolo + p_milan

####################################################
### DIMENSIONS ###
